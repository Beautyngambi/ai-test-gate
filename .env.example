# Copy this file to ".env" and fill in your own values, OR just export
# these three variables in your shell before running the tool.
# NOTE: this prototype reads them straight from the environment. If you use a
# ".env" file, load it yourself first (e.g. `export $(grep -v '^#' .env | xargs)`).

# Your secret API key. Never commit the real key to git.
LLM_API_KEY=your-key-here

# The API endpoint. Leave blank/unset for OpenAI's default.
# Groq example:   https://api.groq.com/openai/v1
LLM_BASE_URL=

# Which model to use.
# Groq example:   llama-3.3-70b-versatile
# OpenAI example: gpt-4o-mini
LLM_MODEL=gpt-4o-mini
